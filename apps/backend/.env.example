# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/diaspo_db

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# Admin 2FA (TOTP)
# After first run, the admin TOTP secret is auto-generated and stored in DB.
# Set this to seed the initial admin account.
ADMIN_EMAIL=admin@diaspo.app
ADMIN_PASSWORD=Admin123!

# CORS — restrict origins in production
CORS_ORIGIN=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=eur
STRIPE_GNF_EUR_RATE=9300
